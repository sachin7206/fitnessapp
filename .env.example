# ============================================
# FitnessApp Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then source it before starting services:
#   source .env
# ============================================

# --- Database ---
export DB_USERNAME=root
export DB_PASSWORD=your-mysql-password

# --- JWT Secret (must be same across all services + gateway) ---
export JWT_SECRET=YourSuperSecretKeyForJWTTokenGenerationPleaseChangeInProduction2024FitnessApp

# --- Gmail SMTP (for password reset emails) ---
# To get an App Password: https://myaccount.google.com/apppasswords
# 1. Enable 2-Step Verification on your Google account
# 2. Go to App Passwords → Generate → Use the 16-char password below
export MAIL_USERNAME=your-email@gmail.com
export MAIL_PASSWORD=your-16-char-app-password

# --- Google Gemini AI API Keys (comma-separated for rotation) ---
# Get keys from: https://aistudio.google.com/apikey
export GEMINI_API_KEYS=your-gemini-api-key-1,your-gemini-api-key-2

